<!DOCTYPE html>
<html lang="en" data-theme="<%= theme || 'light' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/goals.css">
  <title>ZenTrack - Manage Goals</title>
</head>
<body class="dashboard-body">

  <div class="dashboard-bg">
    <div class="d-orb d-orb-3"></div>
    <div class="d-orb d-orb-4"></div>
  </div>

  <aside class="sidebar">
    <div class="sidebar-header">
      <h2 class="brand-logo">Zen<span>Track</span></h2>
    </div>
    <nav class="sidebar-nav">
      <a href="/" class="nav-item"><i class="fas fa-calendar-check"></i> Tracker</a>
      <a href="/goals" class="nav-item active"><i class="fas fa-plus-circle"></i> Manage Goals</a>
      <a href="/analytics" class="nav-item"><i class="fas fa-chart-pie"></i> Analytics</a>
      <a href="/history" class="nav-item"><i class="fas fa-history"></i> History</a>
    </nav>
    <div class="sidebar-footer">
      <div class="user-pill">
        <p class="u-name"><%= user.username %></p>
        <p class="u-email"><%= user.email %></p>
        <a href="/logout" class="logout-link">Logout</a>
      </div>
    </div>
  </aside>

  <main class="main-content">
    <header class="goal-header d-flex justify-content-between align-items-center mb-4">
      <div class="header-text">
        <h1>Manage Your Goals</h1>
        <p class="motto">Add your goals here and fulfill your dream.</p>
      </div>
      <div id="savingStatus" style="display:none;">
         <span class="badge bg-primary px-3 py-2"><i class="fas fa-sync fa-spin"></i> Processing...</span>
      </div>
    </header>

    <div class="goals-container">
      <div class="glass-card form-section">
        <h3>Create New Goal</h3>
        <form id="addGoalForm" class="modern-form">
          <div class="input-group-custom">
            <i class="fas fa-pencil-alt"></i>
            <input type="text" id="goalName" name="name" placeholder="e.g., Morning Meditation" required>
          </div>
          <div class="input-group-custom">
            <i class="fas fa-clock"></i>
            <input type="time" id="goalTime" name="time">
          </div>
          <button type="submit" class="btn-add-goal">
            <i class="fas fa-plus"></i> Set Goal
          </button>
        </form>
      </div>

      <div class="goals-list-section">
        <h3>Your Current Routine</h3>
        <div class="goals-grid" id="goalsGrid">
          <% if (goals.length > 0) { %>
            <% goals.forEach(goal => { %>
              <div class="goal-card" id="goal-<%= goal._id %>">
                <div class="goal-icon">
                  <i class="fas fa-star"></i>
                </div>
                <div class="goal-info">
                  <span class="g-name"><%= goal.name %></span>
                  <span class="g-time"><%= goal.time || 'Flexible Time' %></span>
                </div>
                <div class="goal-actions d-flex gap-2">
                  <a href="/goals/edit/<%= goal._id %>" class="btn-edit"><i class="fas fa-pencil-alt"></i></a>
                  <button type="button" class="btn-delete" onclick="deleteGoal('<%= goal._id %>')">
                    <i class="far fa-trash-alt"></i>
                  </button>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <div class="empty-state" id="emptyState">
              <i class="fas fa-clipboard-list"></i>
              <p>No goals set yet. Start by adding one above!</p>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </main>

  <script>
    const goalsGrid = document.getElementById('goalsGrid');
    const emptyState = document.getElementById('emptyState');
    const savingStatus = document.getElementById('savingStatus');

    // AJAX Add Goal
    document.getElementById('addGoalForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const name = document.getElementById('goalName').value;
      const time = document.getElementById('goalTime').value;
      
      savingStatus.style.display = 'block';

      try {
        const response = await fetch('/goals', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ name, time })
        });
        const result = await response.json();

        if (result.success) {
          if (emptyState) emptyState.remove();
          
          const goal = result.goal;
          const newCard = `
            <div class="goal-card" id="goal-${goal._id}" style="opacity:0; transform:translateY(20px); transition:0.3s">
              <div class="goal-icon"><i class="fas fa-star"></i></div>
              <div class="goal-info">
                <span class="g-name">${goal.name}</span>
                <span class="g-time">${goal.time || 'Flexible Time'}</span>
              </div>
              <div class="goal-actions d-flex gap-2">
                <a href="/goals/edit/${goal._id}" class="btn-edit"><i class="fas fa-pencil-alt"></i></a>
                <button type="button" class="btn-delete" onclick="deleteGoal('${goal._id}')">
                  <i class="far fa-trash-alt"></i>
                </button>
              </div>
            </div>
          `;
          goalsGrid.insertAdjacentHTML('afterbegin', newCard);
          
          // Animate in
          setTimeout(() => {
            const added = document.getElementById(`goal-${goal._id}`);
            added.style.opacity = '1';
            added.style.transform = 'translateY(0)';
          }, 10);

          e.target.reset();
        }
      } catch (err) {
        alert('Failed to add goal');
      } finally {
        savingStatus.style.display = 'none';
      }
    });

    // AJAX Delete Goal
    async function deleteGoal(id) {
      if (!confirm('Are you sure you want to delete this goal?')) return;
      
      savingStatus.style.display = 'block';
      const card = document.getElementById(`goal-${id}`);
      card.style.opacity = '0.5';

      try {
        const response = await fetch(`/goals/delete/${id}`, {
          method: 'POST',
          headers: { 'Accept': 'application/json' }
        });
        const result = await response.json();

        if (result.success) {
          card.style.transform = 'scale(0.8)';
          card.style.opacity = '0';
          setTimeout(() => {
            card.remove();
            if (goalsGrid.children.length === 0) {
               goalsGrid.innerHTML = `
                 <div class="empty-state" id="emptyState">
                   <i class="fas fa-clipboard-list"></i>
                   <p>No goals set yet. Start by adding one above!</p>
                 </div>
               `;
            }
          }, 300);
        }
      } catch (err) {
        alert('Failed to delete goal');
        card.style.opacity = '1';
      } finally {
        savingStatus.style.display = 'none';
      }
    }

    document.getElementById('sidebarToggle')?.addEventListener('click', () => {
      document.querySelector('.sidebar')?.classList.toggle('active');
    });
  </script>
</body>
</html>