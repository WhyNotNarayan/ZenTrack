<!DOCTYPE html>
<html lang="en" data-theme="<%= theme || 'light' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/dashboard.css">
  <title>ZenTrack - History</title>
  <style>
    .history-controls-card {
      background: var(--glass);
      backdrop-filter: blur(10px);
      border: 1px solid var(--glass-border);
      padding: 1.5rem 2rem;
      border-radius: 20px;
      margin-bottom: 2rem;
      display: flex;
      align-items: center;
      gap: 1.5rem;
      box-shadow: 0 10px 30px -5px rgba(0,0,0,0.1);
    }
    .month-picker {
      padding: 0.6rem 1rem;
      border-radius: 12px;
      border: 1px solid var(--border);
      background: var(--bg-card);
      color: var(--text-main);
      font-family: 'Outfit', sans-serif;
      font-weight: 600;
    }
    .btn-zen-view {
      background: var(--primary);
      color: white;
      border: none;
      padding: 0.6rem 1.5rem;
      border-radius: 12px;
      font-weight: 700;
      transition: all 0.3s;
      box-shadow: 0 8px 15px -3px var(--primary-glow);
    }
    .btn-zen-view:hover { transform: translateY(-2px); box-shadow: 0 12px 20px -5px var(--primary-glow); }
  </style>
</head>
<body class="dashboard-body">

  <!-- Premium Background Orbs -->
  <div class="dashboard-bg">
    <div class="d-orb d-orb-1"></div>
    <div class="d-orb d-orb-2"></div>
  </div>

  <aside class="sidebar">
    <div class="sidebar-header">
      <h2 class="brand-logo">Zen<span>Track</span></h2>
    </div>
    <nav class="sidebar-nav">
      <a href="/" class="nav-item"><i class="fas fa-calendar-check"></i> Tracker</a>
      <a href="/goals" class="nav-item"><i class="fas fa-plus-circle"></i> Manage Goals</a>
      <a href="/analytics" class="nav-item"><i class="fas fa-chart-pie"></i> Analytics</a>
      <a href="/history" class="nav-item active"><i class="fas fa-history"></i> History</a>
    </nav>
    <div class="sidebar-footer">
      <div class="user-pill">
        <div>
          <p class="u-name"><%= user.username %></p>
          <p class="u-email"><%= user.email %></p>
          <a href="/logout" class="logout-link">Logout</a>
        </div>
      </div>
    </div>
  </aside>

  <main class="main-content container-fluid">
    <header class="top-bar d-flex flex-wrap justify-content-between align-items-center mb-4">
      <div class="d-flex align-items-center">
        <button class="btn btn-outline-primary d-md-none me-2" id="sidebarToggle">
          <i class="fas fa-bars"></i>
        </button>
        <h1>Tracking History</h1>
      </div>
      <div id="liveClock"></div>
    </header>

    <div class="history-controls-card">
      <form action="/history" method="GET" class="d-flex align-items-center gap-3">
        <label for="monthSelect" class="fw-bold">Select Month:</label>
        <input type="month" id="monthSelect" name="month" value="<%= selectedMonth %>" class="month-picker">
        <button type="submit" class="btn-zen-view">View History</button>
      </form>
      <div class="ms-auto d-none d-md-block">
        <span class="badge rounded-pill bg-primary px-4 py-2 fs-6"><%= displayMonth %></span>
      </div>
    </div>

    <div class="grid-container-card">
      <div class="table-responsive grid-viewport">
        <table class="zen-grid table table-bordered">
          <thead>
            <tr class="day-label-row">
              <th class="corner-label">GOALS</th>
              <th colspan="<%= dates.length %>" class="main-day-header">DAY</th>
            </tr>
            <tr class="date-number-row">
              <th class="sticky-goal-header"></th> 
              <% dates.forEach(date => { %>
                <th class="date-col-header">
                  <%= moment(date).format('D') %>
                </th>
              <% }) %>
            </tr>
          </thead>
          <tbody>
           <% goals.forEach(goal => { %>
            <tr>
              <td class="sticky-goal-column">
                <div class="goal-name-wrapper">
                  <%= goal.name %>
                </div>
              </td>

              <% dates.forEach(date => { 
                const track = tracks.find(t => 
                  t.goal && t.goal.toString() === goal._id.toString() && 
                  moment(t.date).isSame(date, 'day')
                ); 
              %>
                <td class="grid-checkbox-cell" style="background-color: <%= (track && track.completed) ? 'rgba(16, 185, 129, 0.08)' : 'transparent' %>">
                  <div class="cell-check-display">
                    <% if (track && track.completed) { %>
                      <i class="fas fa-check-circle text-success"></i>
                    <% } else { %>
                      <i class="far fa-circle text-muted" style="opacity: 0.2;"></i>
                    <% } %>
                  </div>
                </td>
              <% }) %>
            </tr>
          <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </main>

  <script>
    document.getElementById('sidebarToggle')?.addEventListener('click', () => {
      document.querySelector('.sidebar')?.classList.toggle('active');
    });

    function updateClock() {
      const now = new Date();
      const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
      const dateString = now.toLocaleDateString('en-US', options);
      const timeString = now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
      const clockEl = document.getElementById('liveClock');
      if (clockEl) clockEl.innerHTML = `${dateString} | ${timeString}`;
    }
    setInterval(updateClock, 1000);
    updateClock();
  </script>
</body>
</html>
