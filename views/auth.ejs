<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/styles.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <title>ZenTrack | Join the Community</title>
  <script src="https://accounts.google.com/gsi/client" async defer></script>
  <script>
    // Auto-flip to signup if ?signup param is present
    window.addEventListener('DOMContentLoaded', () => {
      const params = new URLSearchParams(window.location.search);
      if (params.get('signup') === '1') {
        document.getElementById('flipCard').classList.add('flipped');
      }
      // Show success message if redirected after signup
      if (params.get('success')) {
        const msg = document.createElement('div');
        msg.className = 'alert alert-success';
        msg.textContent = decodeURIComponent(params.get('success'));
        document.body.appendChild(msg);
        setTimeout(() => msg.remove(), 5000);
      }
    });
  </script>
</head>

<body>

  <!-- Premium Background Blobs -->
  <div class="bg-gradient"></div>
  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>
  <div class="blob blob-3"></div>

  <% if (error) { %>
    <div class="alert" id="authError">
      <%= error %>
    </div>
    <% } %>

      <div class="auth-container">
        <div class="flip-card" id="flipCard">

          <!-- LOGIN SIDE -->
          <div class="card-face card-front">
            <div class="brand">
              <h1>Zen<span>Track</span></h1>
              <p>Welcome back! Let's stay consistent.</p>
            </div>

            <div class="mascot">
              <div class="eye">
                <div class="pupil"></div>
              </div>
              <div class="eye">
                <div class="pupil"></div>
              </div>
            </div>

            <form action="/login" method="POST" class="auth-form">
              <div class="input-group">
                <input type="email" name="email" placeholder="Email Address" required>
              </div>
              <div class="input-group">
                <input type="password" name="password" class="password-field" placeholder="Password" required>
              </div>
              <button type="submit" class="btn-submit">Sign In</button>
            </form>

            <div class="divider"><span>OR</span></div>

            <div id="google-login-btn"></div>

            <div class="footer">
              New here? <a href="#" class="flip-to-signup">Create an account</a>
            </div>
          </div>

          <!-- SIGNUP SIDE -->
          <div class="card-face card-back">
            <div class="brand">
              <h1>Zen<span>Track</span></h1>
              <p>Join us and start your journey.</p>
            </div>

            <div class="mascot">
              <div class="eye">
                <div class="pupil"></div>
              </div>
              <div class="eye">
                <div class="pupil"></div>
              </div>
            </div>

            <form action="/signup" method="POST" class="auth-form" id="signupForm">
              <div class="input-group">
                <input type="email" name="email" placeholder="Email Address" required>
              </div>
              <div class="input-group">
                <input type="text" name="username" placeholder="Username" required>
              </div>
              <div class="input-group">
                <input type="password" name="password" class="password-field" placeholder="Password" required>
              </div>
              <div class="input-group">
                <input type="tel" name="mobile" id="mobileInput" placeholder="10-digit Mobile Number"
                  pattern="[0-9]{10}" required title="10-digit mobile number">
              </div>
              <button type="submit" class="btn-submit">Level Up</button>
            </form>

            <div class="divider"><span>OR</span></div>

            <div id="google-signup-btn"></div>

            <div class="footer">
              Already a member? <a href="#" class="flip-to-login">Login</a>
            </div>
          </div>

        </div>
      </div>

      <script>
        // --- Authentication Handling ---
        const GOOGLE_CLIENT_ID = "<%= googleClientId %>";

        function handleCredentialResponse(response) {
          fetch('/auth/google', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ idToken: response.credential })
          })
            .then(res => res.json())
            .then(data => {
              if (data.success) {
                window.location.href = data.redirectUrl || '/';
              } else {
                showError(data.error || 'Google Login Failed');
              }
            })
            .catch(err => showError('Network Error: ' + err.message));
        }

        window.onGoogleLibraryLoad = function () {
          if (GOOGLE_CLIENT_ID && GOOGLE_CLIENT_ID !== "undefined" && GOOGLE_CLIENT_ID !== "") {
            google.accounts.id.initialize({
              client_id: GOOGLE_CLIENT_ID,
              callback: handleCredentialResponse
            });

            const renderOptions = {
              theme: "outline",
              size: "large",
              width: 320,
              text: "continue_with",
              shape: "pill"
            };

            google.accounts.id.renderButton(
              document.getElementById("google-login-btn"),
              renderOptions
            );
            google.accounts.id.renderButton(
              document.getElementById("google-signup-btn"),
              renderOptions
            );
          } else {
            // Hide dividers if no Google Client ID
            document.querySelectorAll('.divider').forEach(d => d.style.display = 'none');
            console.warn("GOOGLE_CLIENT_ID is missing — Google buttons hidden");
          }
        };

        // --- UI Interactions ---
        const flipCard = document.getElementById('flipCard');

        document.querySelector('.flip-to-signup').addEventListener('click', (e) => {
          e.preventDefault();
          flipCard.classList.add('flipped');
        });

        document.querySelector('.flip-to-login').addEventListener('click', (e) => {
          e.preventDefault();
          flipCard.classList.remove('flipped');
        });

        // Eye Movement
        document.addEventListener('mousemove', (e) => {
          document.querySelectorAll('.pupil').forEach(pupil => {
            const rect = pupil.parentElement.getBoundingClientRect();
            const centerX = rect.left + rect.width / 2;
            const centerY = rect.top + rect.height / 2;

            const angle = Math.atan2(e.clientY - centerY, e.clientX - centerX);
            const distance = 8;

            const moveX = Math.cos(angle) * distance;
            const moveY = Math.sin(angle) * distance;

            pupil.style.transform = `translate(${moveX}px, ${moveY}px)`;
          });
        });

        // Eye Close on Password
        document.querySelectorAll('.password-field').forEach(field => {
          field.addEventListener('focus', () => {
            document.querySelectorAll('.eye').forEach(eye => eye.classList.add('closed'));
          });
          field.addEventListener('blur', () => {
            document.querySelectorAll('.eye').forEach(eye => eye.classList.remove('closed'));
          });
        });

        // Mobile Number Validation
        const mobileInput = document.getElementById('mobileInput');
        if (mobileInput) {
          mobileInput.addEventListener('input', (e) => {
            e.target.value = e.target.value.replace(/\D/g, '').slice(0, 10);
          });
        }

        // Error Alert Auto-hide
        const errorAlert = document.getElementById('authError');
        if (errorAlert) {
          setTimeout(() => {
            errorAlert.style.display = 'none';
          }, 5000);
        }

        function showError(msg) {
          const alert = document.createElement('div');
          alert.className = 'alert';
          alert.textContent = msg;
          document.body.appendChild(alert);
          setTimeout(() => alert.remove(), 5000);
        }
      </script>
</body>

</html>